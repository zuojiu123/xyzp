{"remainingRequest":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\src\\views\\company\\CompanyDashboard.vue?vue&type=script&lang=js","dependencies":[{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\src\\views\\company\\CompanyDashboard.vue","mtime":1760069333373},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1759980453610},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1759980457299},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1759980453610},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1759980458675}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["CompanyDashboard.vue"],"names":[],"mappings":";AAoIA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA","file":"CompanyDashboard.vue","sourceRoot":"src/views/company","sourcesContent":["<template>\n  <div class=\"company-dashboard\">\n    <div class=\"welcome-banner\">\n      <div class=\"welcome-text\">\n        <h2>欢迎回来，{{ companyInfo.name || '企业用户' }}</h2>\n        <p>这是您的企业数据概览</p>\n      </div>\n    </div>\n\n    <!-- 统计卡片 -->\n    <el-row :gutter=\"20\" class=\"stats-row\">\n      <el-col :span=\"6\">\n        <el-card class=\"stat-card\">\n          <div class=\"stat-content\">\n            <div class=\"stat-number\">{{ stats.totalJobs }}</div>\n            <div class=\"stat-label\">发布职位</div>\n          </div>\n          <i class=\"el-icon-suitcase stat-icon\"></i>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card class=\"stat-card\">\n          <div class=\"stat-content\">\n            <div class=\"stat-number\">{{ stats.totalApplications }}</div>\n            <div class=\"stat-label\">收到申请</div>\n          </div>\n          <i class=\"el-icon-user stat-icon\"></i>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card class=\"stat-card\">\n          <div class=\"stat-content\">\n            <div class=\"stat-number\">{{ stats.pendingApplications }}</div>\n            <div class=\"stat-label\">待处理申请</div>\n          </div>\n          <i class=\"el-icon-time stat-icon\"></i>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card class=\"stat-card\">\n          <div class=\"stat-content\">\n            <div class=\"stat-number\">{{ stats.hiredCount }}</div>\n            <div class=\"stat-label\">已录用</div>\n          </div>\n          <i class=\"el-icon-check stat-icon\"></i>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <!-- 快速操作 -->\n    <el-row :gutter=\"20\" class=\"quick-actions\">\n      <el-col :span=\"12\">\n        <el-card>\n          <div slot=\"header\">\n            <span>快速操作</span>\n          </div>\n          <div class=\"action-buttons\">\n            <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"$router.push('/company/jobs?action=create')\">\n              发布新职位\n            </el-button>\n            <el-button icon=\"el-icon-view\" @click=\"$router.push('/company/applications')\">\n              查看申请\n            </el-button>\n            <el-button icon=\"el-icon-setting\" @click=\"$router.push('/company/profile')\">\n              企业设置\n            </el-button>\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"12\">\n        <el-card>\n          <div slot=\"header\">\n            <span>最新申请</span>\n          </div>\n          <div class=\"recent-applications\">\n            <div v-for=\"application in recentApplications\" :key=\"application.id\" class=\"application-item\">\n              <div class=\"applicant-info\">\n                <strong>{{ application.name }}</strong>\n                <span class=\"job-title\">申请：{{ application.jobTitle }}</span>\n              </div>\n              <div class=\"application-time\">\n                {{ formatDate(application.createTime) }}\n              </div>\n            </div>\n            <div v-if=\"recentApplications.length === 0\" class=\"no-data\">\n              暂无新申请\n            </div>\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n\n    <!-- 职位管理 -->\n    <el-card class=\"jobs-section\">\n      <div slot=\"header\">\n        <span>我的职位</span>\n        <el-button style=\"float: right; padding: 3px 0\" type=\"text\" @click=\"$router.push('/company/jobs')\">\n          查看全部\n        </el-button>\n      </div>\n      <el-table :data=\"recentJobs\" style=\"width: 100%\">\n        <el-table-column prop=\"title\" label=\"职位名称\" width=\"200\"></el-table-column>\n        <el-table-column prop=\"position\" label=\"工作地点\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"salary\" label=\"薪资范围\" width=\"150\">\n          <template slot-scope=\"scope\">\n            {{ scope.row.minSalary }}-{{ scope.row.maxSalary }}K\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"getJobStatusType(scope.row.status)\">\n              {{ getJobStatusText(scope.row.status) }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createTime\" label=\"发布时间\" width=\"180\">\n          <template slot-scope=\"scope\">\n            {{ formatDate(scope.row.createTime) }}\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\">\n          <template slot-scope=\"scope\">\n            <el-button size=\"mini\" @click=\"editJob(scope.row)\">编辑</el-button>\n            <el-button size=\"mini\" type=\"danger\" @click=\"deleteJob(scope.row)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CompanyDashboard',\n  data() {\n    return {\n      companyInfo: {},\n      stats: {\n        totalJobs: 0,\n        totalApplications: 0,\n        pendingApplications: 0,\n        hiredCount: 0\n      },\n      recentApplications: [],\n      recentJobs: []\n    }\n  },\n  mounted() {\n    this.loadDashboardData()\n  },\n  methods: {\n    async loadDashboardData() {\n      try {\n        // 加载企业信息\n        const companyData = await this.$api.company.getCurrentCompany()\n        \n        if (!companyData || !companyData.id) {\n          this.$message.warning('请先完善企业信息')\n          this.$router.push('/company/register')\n          return\n        }\n        \n        if (companyData.status === 'Check_Pending') {\n          this.$message.info('企业信息审核中，请耐心等待')\n        } else if (companyData.status === 'Audit_Failed') {\n          this.$message.error('企业审核未通过: ' + (companyData.replyContent || ''))\n        }\n        \n        this.companyInfo = companyData\n        \n        // 加载职位数据\n        const jobsResponse = await this.$api.employment.getUserJobs(1, 100)\n        const allJobs = jobsResponse.list || []\n        \n        // 加载申请数据\n        const applicationsResponse = await this.$api.employmentUser.getCompanyApplications(1, 100, {\n          companyId: companyData.id\n        })\n        const allApplications = applicationsResponse.list || []\n        \n        // 统计数据\n        this.stats = {\n          totalJobs: allJobs.length,\n          totalApplications: allApplications.length,\n          pendingApplications: allApplications.filter(a => a.replyStatus === 'Wait_For_Reply').length,\n          hiredCount: allApplications.filter(a => a.replyStatus === 'Agree_With_Induction').length\n        }\n        \n        // 最新申请 (前5条)\n        this.recentApplications = allApplications\n          .sort((a, b) => b.createTime - a.createTime)\n          .slice(0, 5)\n          .map(app => ({\n            id: app.id,\n            name: app.name,\n            jobTitle: app.employmentModel ? app.employmentModel.title : '未知职位',\n            createTime: app.createTime\n          }))\n        \n        // 最近职位 (前5条)\n        this.recentJobs = allJobs\n          .sort((a, b) => b.createTime - a.createTime)\n          .slice(0, 5)\n          .map(job => ({\n            id: job.id,\n            title: job.title,\n            position: job.position,\n            minSalary: job.minSalary,\n            maxSalary: job.maxSalary,\n            status: job.status,\n            createTime: job.createTime\n          }))\n      } catch (error) {\n        console.error('加载数据失败:', error)\n        this.$message.error('加载数据失败')\n      }\n    },\n    \n    editJob(job) {\n      this.$router.push(`/company/jobs?action=edit&id=${job.id}`)\n    },\n    \n    deleteJob(job) {\n      this.$confirm('确认删除该职位?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        // 调用删除API\n        this.$message.success('删除成功')\n        this.loadDashboardData()\n      })\n    },\n    \n    getJobStatusType(status) {\n      const statusMap = {\n        0: 'warning',  // 待审核\n        1: 'success',  // 已通过\n        2: 'danger'    // 已驳回\n      }\n      return statusMap[status] || 'info'\n    },\n    \n    getJobStatusText(status) {\n      const statusMap = {\n        0: '审核中',\n        1: '招聘中',\n        2: '已驳回'\n      }\n      return statusMap[status] || '未知'\n    },\n    \n    formatDate(timestamp) {\n      if (!timestamp) return ''\n      return new Date(timestamp).toLocaleString()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.company-dashboard {\n  min-height: calc(100vh - 108px);\n}\n\n.welcome-banner {\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  border-radius: 12px;\n  padding: 32px;\n  margin-bottom: 24px;\n  box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);\n}\n\n.welcome-text h2 {\n  margin: 0 0 8px 0;\n  color: #ffffff;\n  font-size: 24px;\n  font-weight: 600;\n}\n\n.welcome-text p {\n  margin: 0;\n  color: rgba(255, 255, 255, 0.9);\n  font-size: 14px;\n}\n\n.stats-row {\n  margin-bottom: 24px;\n}\n\n.stat-card {\n  position: relative;\n  overflow: hidden;\n  border-radius: 12px;\n  border: none;\n  box-shadow: 0 2px 12px rgba(44, 95, 141, 0.08);\n  transition: all 0.3s;\n}\n\n.stat-card:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 4px 20px rgba(44, 95, 141, 0.15);\n}\n\n.stat-card .el-card__body {\n  padding: 24px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n}\n\n.stat-content {\n  flex: 1;\n}\n\n.stat-number {\n  font-size: 32px;\n  font-weight: 600;\n  color: #2c5f8d;\n  margin-bottom: 8px;\n}\n\n.stat-label {\n  color: #666;\n  font-size: 14px;\n}\n\n.stat-icon {\n  font-size: 48px;\n  color: #4a9eff;\n  opacity: 0.2;\n}\n\n.quick-actions {\n  margin-bottom: 24px;\n}\n\n.quick-actions .el-card {\n  border-radius: 12px;\n  border: none;\n  box-shadow: 0 2px 12px rgba(44, 95, 141, 0.08);\n}\n\n.action-buttons {\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n\n.action-buttons .el-button {\n  justify-content: flex-start;\n}\n\n.recent-applications {\n  max-height: 300px;\n  overflow-y: auto;\n}\n\n.application-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 10px 0;\n  border-bottom: 1px solid #eee;\n}\n\n.application-item:last-child {\n  border-bottom: none;\n}\n\n.applicant-info {\n  display: flex;\n  flex-direction: column;\n}\n\n.job-title {\n  color: #666;\n  font-size: 12px;\n  margin-top: 5px;\n}\n\n.application-time {\n  color: #999;\n  font-size: 12px;\n}\n\n.no-data {\n  text-align: center;\n  color: #999;\n  padding: 20px;\n}\n\n.jobs-section {\n  margin-bottom: 24px;\n  border-radius: 12px;\n  border: none;\n  box-shadow: 0 2px 12px rgba(44, 95, 141, 0.08);\n}\n\n/* 响应式设计 */\n@media (max-width: 768px) {\n  .stats-row .el-col {\n    margin-bottom: 20px;\n  }\n  \n  .action-buttons {\n    flex-direction: column;\n  }\n}\n</style>"]}]}