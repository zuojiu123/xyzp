{"remainingRequest":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\src\\views\\company\\CompanyProfile.vue?vue&type=style&index=0&id=0006c9f8&scoped=true&lang=css","dependencies":[{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\src\\views\\company\\CompanyProfile.vue","mtime":1760069390198},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\css-loader\\dist\\cjs.js","mtime":1759980455428},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1759980460265},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\postcss-loader\\src\\index.js","mtime":1759980457291},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1759980453610},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1759980458675}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["CompanyProfile.vue"],"names":[],"mappings":";AA6JA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA","file":"CompanyProfile.vue","sourceRoot":"src/views/company","sourcesContent":["<template>\n  <div class=\"company-profile\">\n    <el-card>\n        <el-form :model=\"companyInfo\" :rules=\"rules\" ref=\"form\" label-width=\"120px\">\n          <el-form-item label=\"公司名称\" prop=\"name\">\n            <el-input v-model=\"companyInfo.name\" placeholder=\"请输入公司名称\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"营业执照号\" prop=\"companyNumber\">\n            <el-input v-model=\"companyInfo.companyNumber\" placeholder=\"请输入营业执照号\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"公司规模\" prop=\"number\">\n            <el-select v-model=\"companyInfo.number\" placeholder=\"请选择公司规模\">\n              <el-option label=\"1-50人\" :value=\"50\"></el-option>\n              <el-option label=\"51-200人\" :value=\"200\"></el-option>\n              <el-option label=\"201-500人\" :value=\"500\"></el-option>\n              <el-option label=\"501-1000人\" :value=\"1000\"></el-option>\n              <el-option label=\"1000人以上\" :value=\"5000\"></el-option>\n            </el-select>\n          </el-form-item>\n          \n          <el-form-item label=\"公司Logo\">\n            <el-upload\n              class=\"logo-uploader\"\n              action=\"/api/upload\"\n              :show-file-list=\"false\"\n              :on-success=\"handleLogoSuccess\"\n              :before-upload=\"beforeLogoUpload\"\n            >\n              <img v-if=\"companyInfo.companyLogo\" :src=\"companyInfo.companyLogo\" class=\"logo\">\n              <i v-else class=\"el-icon-plus logo-uploader-icon\"></i>\n            </el-upload>\n          </el-form-item>\n          \n          <el-form-item label=\"公司描述\" prop=\"description\">\n            <el-input \n              type=\"textarea\" \n              v-model=\"companyInfo.description\" \n              :rows=\"6\"\n              placeholder=\"请详细介绍公司情况、发展历程、企业文化等\"\n            ></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"审核状态\">\n            <el-tag :type=\"getStatusType(companyInfo.status)\">\n              {{ getStatusText(companyInfo.status) }}\n            </el-tag>\n            <div v-if=\"companyInfo.replyContent\" class=\"reply-content\">\n              <strong>审核意见：</strong>{{ companyInfo.replyContent }}\n            </div>\n          </el-form-item>\n          \n          <el-form-item>\n            <el-button type=\"primary\" @click=\"updateCompany\" :loading=\"loading\">\n              保存修改\n            </el-button>\n            <el-button @click=\"$router.go(-1)\">返回</el-button>\n          </el-form-item>\n        </el-form>\n      </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CompanyProfile',\n  data() {\n    return {\n      companyInfo: {\n        name: '',\n        companyNumber: '',\n        number: '',\n        companyLogo: '',\n        description: '',\n        status: 0,\n        replyContent: ''\n      },\n      rules: {\n        name: [\n          { required: true, message: '请输入公司名称', trigger: 'blur' }\n        ],\n        companyNumber: [\n          { required: true, message: '请输入营业执照号', trigger: 'blur' }\n        ],\n        number: [\n          { required: true, message: '请选择公司规模', trigger: 'change' }\n        ],\n        description: [\n          { required: true, message: '请输入公司描述', trigger: 'blur' },\n          { min: 50, message: '公司描述不能少于50个字符', trigger: 'blur' }\n        ]\n      },\n      loading: false\n    }\n  },\n  methods: {\n    async loadCompanyInfo() {\n      try {\n        const data = await this.$api.company.getCurrentCompany()\n        this.companyInfo = data\n      } catch (error) {\n        this.$message.error('获取企业信息失败')\n      }\n    },\n    \n    updateCompany() {\n      this.$refs.form.validate(async (valid) => {\n        if (valid) {\n          this.loading = true\n          try {\n            await this.$api.company.updateCompany(this.companyInfo)\n            this.$message.success('更新成功')\n          } catch (error) {\n            this.$message.error('更新失败：' + (error.message || '未知错误'))\n          } finally {\n            this.loading = false\n          }\n        }\n      })\n    },\n    \n    handleLogoSuccess(res, file) {\n      this.companyInfo.companyLogo = URL.createObjectURL(file.raw)\n    },\n    \n    beforeLogoUpload(file) {\n      const isJPG = file.type === 'image/jpeg' || file.type === 'image/png'\n      const isLt2M = file.size / 1024 / 1024 < 2\n\n      if (!isJPG) {\n        this.$message.error('上传头像图片只能是 JPG/PNG 格式!')\n      }\n      if (!isLt2M) {\n        this.$message.error('上传头像图片大小不能超过 2MB!')\n      }\n      return isJPG && isLt2M\n    },\n    \n    getStatusType(status) {\n      const types = { 0: 'warning', 1: 'success', 2: 'danger' }\n      return types[status] || 'info'\n    },\n    \n    getStatusText(status) {\n      const texts = { 0: '待审核', 1: '已通过', 2: '已拒绝' }\n      return texts[status] || '未知'\n    }\n  },\n  \n  async mounted() {\n    await this.loadCompanyInfo()\n  }\n}\n</script>\n\n<style scoped>\n.company-profile {\n  min-height: calc(100vh - 108px);\n  max-width: 900px;\n  margin: 0 auto;\n}\n\n.el-card {\n  border-radius: 12px;\n  border: none;\n  box-shadow: 0 2px 12px rgba(44, 95, 141, 0.08);\n}\n\n.logo-uploader .el-upload {\n  border: 1px dashed #d9d9d9;\n  border-radius: 6px;\n  cursor: pointer;\n  position: relative;\n  overflow: hidden;\n}\n\n.logo-uploader .el-upload:hover {\n  border-color: #409EFF;\n}\n\n.logo-uploader-icon {\n  font-size: 28px;\n  color: #8c939d;\n  width: 120px;\n  height: 120px;\n  line-height: 120px;\n  text-align: center;\n}\n\n.logo {\n  width: 120px;\n  height: 120px;\n  display: block;\n  object-fit: cover;\n}\n\n.reply-content {\n  margin-top: 10px;\n  padding: 10px;\n  background: #f5f5f5;\n  border-radius: 4px;\n  color: #666;\n}\n\n.el-button--primary {\n  background: linear-gradient(90deg, #4a9eff 0%, #3d7ecc 100%);\n  border: none;\n}\n\n.el-button--primary:hover {\n  background: linear-gradient(90deg, #3d7ecc 0%, #2c5f8d 100%);\n}\n\n.el-form-item__label {\n  color: #2c5f8d;\n  font-weight: 500;\n}\n</style>"]}]}