            localStorage.removeItem('userInfo')\n          }\n        }\n      } catch (error) {\n        console.error('初始化认证错误:', error)\n      }\n    },\n    login({ commit }, { user, token }) {\n      commit('SET_USER', user)\n      commit('SET_TOKEN', token)\n    },\n    logout({ commit }) {\n      commit('SET_USER', null)\n      commit('SET_TOKEN', null)\n      localStorage.removeItem('userInfo')\n    }\n  }\n})"],"mappings":"AAAA,OAAOA,GAAG,MAAM,KAAK;AACrB,OAAOC,IAAI,MAAM,MAAM;AAEvBD,GAAG,CAACE,GAAG,CAACD,IAAI,CAAC;AAEb,eAAe,IAAIA,IAAI,CAACE,KAAK,CAAC;EAC5BC,KAAK,EAAE;IACLC,IAAI,EAAE,IAAI;IACVC,KAAK,EAAE;EACT,CAAC;EACDC,SAAS,EAAE;IACTC,QAAQA,CAACJ,KAAK,EAAEC,IAAI,EAAE;MACpBD,KAAK,CAACC,IAAI,GAAGA,IAAI;IACnB,CAAC;IACDI,SAASA,CAACL,KAAK,EAAEE,KAAK,EAAE;MACtBF,KAAK,CAACE,KAAK,GAAGA,KAAK;MACnB,IAAIA,KAAK,EAAE;QACTI,YAAY,CAACC,OAAO,CAAC,OAAO,EAAEL,KAAK,CAAC;MACtC,CAAC,MAAM;QACLI,YAAY,CAACE,UAAU,CAAC,OAAO,CAAC;MAClC;IACF;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,QAAQA,CAAC;MAAEC;IAAO,CAAC,EAAE;MACnB,IAAI;QACF,MAAMT,KAAK,GAAGI,YAAY,CAACM,OAAO,CAAC,OAAO,CAAC;QAC3C,MAAMC,QAAQ,GAAGP,YAAY,CAACM,OAAO,CAAC,UAAU,CAAC;QAEjDE,OAAO,CAACC,GAAG,CAAC,UAAU,EAAE;UAAEb,KAAK;UAAEW;QAAS,CAAC,CAAC;QAE5C,IAAIX,KAAK,EAAE;UACTS,MAAM,CAAC,WAAW,EAAET,KAAK,CAAC;QAC5B;QACA,IAAIW,QAAQ,EAAE;UACZ,IAAI;YACF,MAAMG,UAAU,GAAGC,IAAI,CAACC,KAAK,CAACL,QAAQ,CAAC;YACvCF,MAAM,CAAC,UAAU,EAAEK,UAAU,CAAC;UAChC,CAAC,CAAC,OAAOG,CAAC,EAAE;YACVL,OAAO,CAACM,KAAK,CAAC,WAAW,EAAED,CAAC,CAAC;YAC7Bb,YAAY,CAACE,UAAU,CAAC,UAAU,CAAC;UACrC;QACF;MACF,CAAC,CAAC,OAAOY,KAAK,EAAE;QACdN,OAAO,CAACM,KAAK,CAAC,UAAU,EAAEA,KAAK,CAAC;MAClC;IACF,CAAC;IACDC,KAAKA,CAAC;MAAEV;IAAO,CAAC,EAAE;MAAEV,IAAI;MAAEC;IAAM,CAAC,EAAE;MACjCS,MAAM,CAAC,UAAU,EAAEV,IAAI,CAAC;MACxBU,MAAM,CAAC,WAAW,EAAET,KAAK,CAAC;IAC5B,CAAC;IACDoB,MAAMA,CAAC;MAAEX;IAAO,CAAC,EAAE;MACjBA,MAAM,CAAC,UAAU,EAAE,IAAI,CAAC;MACxBA,MAAM,CAAC,WAAW,EAAE,IAAI,CAAC;MACzBL,YAAY,CAACE,UAAU,CAAC,UAAU,CAAC;IACrC;EACF;AACF,CAAC,CAAC","ignoreList":[]}]}