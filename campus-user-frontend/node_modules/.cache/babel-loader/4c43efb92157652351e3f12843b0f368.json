{"remainingRequest":"B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\babel-loader\\lib\\index.js!B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\src\\views\\company\\CompanyApplications.vue?vue&type=script&lang=js","dependencies":[{"path":"B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\src\\views\\company\\CompanyApplications.vue","mtime":1760072689935},{"path":"B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1759980453610},{"path":"B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1759980457299},{"path":"B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1759980453610},{"path":"B:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1759980458675}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["name","data","applicationList","currentPage","pageSize","total","loading","filters","replyStatus","detailVisible","currentApplication","replyContent","replying","mounted","loadApplications","methods","company","$api","getCurrentCompany","id","$message","warning","$router","push","params","companyId","employmentUser","getCompanyApplications","list","map","app","jobTitle","employmentModel","title","error","handlePageChange","page","viewDetail","application","handleApplication","status","action","$confirm","type","updateApplication","success","replyApplication","trim","getStatusType","types","getStatusText","texts","formatTime","timestamp","Date","toLocaleString"],"sources":["src/views/company/CompanyApplications.vue"],"sourcesContent":["<template>\n  <div class=\"company-applications\">\n    <div class=\"container\">\n      <div class=\"header\">\n        <h2>申请管理</h2>\n        <el-select v-model=\"filters.replyStatus\" placeholder=\"筛选状态\" clearable @change=\"loadApplications\" style=\"width: 200px\">\n          <el-option label=\"等待回复\" value=\"Wait_For_Reply\"></el-option>\n          <el-option label=\"同意入职\" value=\"Agree_With_Induction\"></el-option>\n          <el-option label=\"已拒绝\" value=\"Rejected\"></el-option>\n        </el-select>\n      </div>\n\n      <el-card>\n        <el-table :data=\"applicationList\" border v-loading=\"loading\">\n          <el-table-column prop=\"name\" label=\"姓名\" width=\"120\"></el-table-column>\n          <el-table-column prop=\"phone\" label=\"联系电话\" width=\"130\"></el-table-column>\n          <el-table-column prop=\"jobTitle\" label=\"申请职位\" width=\"200\"></el-table-column>\n          <el-table-column prop=\"introduce\" label=\"自我介绍\" show-overflow-tooltip></el-table-column>\n          <el-table-column label=\"投递时间\" width=\"180\">\n            <template slot-scope=\"scope\">\n              {{ formatTime(scope.row.createTime) }}\n            </template>\n          </el-table-column>\n          <el-table-column prop=\"replyStatus\" label=\"状态\" width=\"120\">\n            <template slot-scope=\"scope\">\n              <el-tag :type=\"getStatusType(scope.row.replyStatus)\">\n                {{ getStatusText(scope.row.replyStatus) }}\n              </el-tag>\n            </template>\n          </el-table-column>\n          <el-table-column label=\"操作\" width=\"200\">\n            <template slot-scope=\"scope\">\n              <el-button size=\"mini\" @click=\"viewDetail(scope.row)\">查看</el-button>\n              <el-button v-if=\"scope.row.replyStatus === 'Wait_For_Reply'\" size=\"mini\" type=\"success\" @click=\"handleApplication(scope.row, 'Agree_With_Induction')\">\n                通过\n              </el-button>\n              <el-button v-if=\"scope.row.replyStatus === 'Wait_For_Reply'\" size=\"mini\" type=\"danger\" @click=\"handleApplication(scope.row, 'Rejected')\">\n                拒绝\n              </el-button>\n            </template>\n          </el-table-column>\n        </el-table>\n\n        <div class=\"pagination\">\n          <el-pagination\n            @current-change=\"handlePageChange\"\n            :current-page=\"currentPage\"\n            :page-size=\"pageSize\"\n            layout=\"total, prev, pager, next\"\n            :total=\"total\">\n          </el-pagination>\n        </div>\n      </el-card>\n\n      <!-- 详情对话框 -->\n      <el-dialog title=\"申请详情\" :visible.sync=\"detailVisible\" width=\"600px\">\n        <div v-if=\"currentApplication\">\n          <el-descriptions :column=\"2\" border>\n            <el-descriptions-item label=\"姓名\">{{ currentApplication.name }}</el-descriptions-item>\n            <el-descriptions-item label=\"联系电话\">{{ currentApplication.phone }}</el-descriptions-item>\n            <el-descriptions-item label=\"申请职位\" :span=\"2\">{{ currentApplication.jobTitle }}</el-descriptions-item>\n            <el-descriptions-item label=\"投递时间\" :span=\"2\">\n              {{ formatTime(currentApplication.createTime) }}\n            </el-descriptions-item>\n            <el-descriptions-item label=\"自我介绍\" :span=\"2\">\n              <div class=\"introduce-content\">{{ currentApplication.introduce }}</div>\n            </el-descriptions-item>\n          </el-descriptions>\n          \n          <div class=\"reply-section\">\n            <h4>回复</h4>\n            <el-input type=\"textarea\" v-model=\"replyContent\" :rows=\"3\" placeholder=\"请输入回复内容...\"></el-input>\n            <div class=\"reply-actions\">\n              <el-button type=\"success\" @click=\"replyApplication('Agree_With_Induction')\" :loading=\"replying\">\n                通过并回复\n              </el-button>\n              <el-button type=\"danger\" @click=\"replyApplication('Rejected')\" :loading=\"replying\">\n                拒绝并回复\n              </el-button>\n            </div>\n          </div>\n        </div>\n      </el-dialog>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CompanyApplications',\n  data() {\n    return {\n      applicationList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      loading: false,\n      filters: {\n        replyStatus: ''\n      },\n      detailVisible: false,\n      currentApplication: null,\n      replyContent: '',\n      replying: false\n    }\n  },\n  async mounted() {\n    await this.loadApplications()\n  },\n  methods: {\n    async loadApplications() {\n      this.loading = true\n      try {\n        const company = await this.$api.company.getCurrentCompany()\n        if (!company || !company.id) {\n          this.$message.warning('请先完善企业信息')\n          this.$router.push('/company/register')\n          return\n        }\n        \n        const params = { companyId: company.id }\n        if (this.filters.replyStatus) {\n          params.replyStatus = this.filters.replyStatus\n        }\n        \n        const data = await this.$api.employmentUser.getCompanyApplications(this.currentPage, this.pageSize, params)\n        this.applicationList = (data.list || []).map(app => ({\n          ...app,\n          jobTitle: app.employmentModel ? app.employmentModel.title : '未知职位'\n        }))\n        this.total = data.total || 0\n      } catch (error) {\n        this.$message.error('获取申请列表失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    \n    handlePageChange(page) {\n      this.currentPage = page\n      this.loadApplications()\n    },\n    \n    viewDetail(application) {\n      this.currentApplication = application\n      this.replyContent = application.replyContent || ''\n      this.detailVisible = true\n    },\n    \n    async handleApplication(application, status) {\n      try {\n        const action = status === 'Agree_With_Induction' ? '通过' : '拒绝'\n        await this.$confirm(`确定要${action}这份申请吗？`, '提示', { type: 'warning' })\n        \n        await this.$api.employmentUser.updateApplication({\n          id: application.id,\n          replyStatus: status,\n          replyContent: status === 'Agree_With_Induction' ? '恭喜您通过了初步筛选，请保持电话畅通' : '很遗憾，您的申请未通过筛选'\n        })\n        \n        this.$message.success(`${action}成功`)\n        await this.loadApplications()\n      } catch (error) {\n        if (error !== 'cancel') {\n          this.$message.error('操作失败')\n        }\n      }\n    },\n    \n    async replyApplication(status) {\n      if (!this.replyContent.trim()) {\n        this.$message.warning('请输入回复内容')\n        return\n      }\n      \n      this.replying = true\n      try {\n        await this.$api.employmentUser.updateApplication({\n          id: this.currentApplication.id,\n          replyStatus: status,\n          replyContent: this.replyContent\n        })\n        \n        this.$message.success('回复成功')\n        this.detailVisible = false\n        await this.loadApplications()\n      } catch (error) {\n        this.$message.error('回复失败')\n      } finally {\n        this.replying = false\n      }\n    },\n    \n    getStatusType(replyStatus) {\n      const types = {\n        'Wait_For_Reply': 'warning',\n        'Agree_With_Induction': 'success',\n        'Rejected': 'danger'\n      }\n      return types[replyStatus] || 'info'\n    },\n    \n    getStatusText(replyStatus) {\n      const texts = {\n        'Wait_For_Reply': '等待回复',\n        'Agree_With_Induction': '同意入职',\n        'Rejected': '已拒绝'\n      }\n      return texts[replyStatus] || '未知'\n    },\n    \n    formatTime(timestamp) {\n      if (!timestamp) return ''\n      return new Date(timestamp).toLocaleString()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.company-applications {\n  padding: 20px;\n  background: #f5f5f5;\n  min-height: calc(100vh - 120px);\n}\n\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\nh2 {\n  margin: 0;\n  color: #333;\n}\n\n.pagination {\n  text-align: center;\n  margin-top: 20px;\n}\n\n.introduce-content {\n  max-height: 100px;\n  overflow-y: auto;\n  line-height: 1.6;\n}\n\n.reply-section {\n  margin-top: 20px;\n  padding-top: 20px;\n  border-top: 1px solid #eee;\n}\n\n.reply-section h4 {\n  margin-bottom: 10px;\n  color: #333;\n}\n\n.reply-actions {\n  margin-top: 10px;\n  text-align: right;\n}\n\n.reply-actions .el-button {\n  margin-left: 10px;\n}\n</style>\n"],"mappings":"AAwFA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,eAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;MACAC,OAAA;MACAC,OAAA;QACAC,WAAA;MACA;MACAC,aAAA;MACAC,kBAAA;MACAC,YAAA;MACAC,QAAA;IACA;EACA;EACA,MAAAC,QAAA;IACA,WAAAC,gBAAA;EACA;EACAC,OAAA;IACA,MAAAD,iBAAA;MACA,KAAAR,OAAA;MACA;QACA,MAAAU,OAAA,cAAAC,IAAA,CAAAD,OAAA,CAAAE,iBAAA;QACA,KAAAF,OAAA,KAAAA,OAAA,CAAAG,EAAA;UACA,KAAAC,QAAA,CAAAC,OAAA;UACA,KAAAC,OAAA,CAAAC,IAAA;UACA;QACA;QAEA,MAAAC,MAAA;UAAAC,SAAA,EAAAT,OAAA,CAAAG;QAAA;QACA,SAAAZ,OAAA,CAAAC,WAAA;UACAgB,MAAA,CAAAhB,WAAA,QAAAD,OAAA,CAAAC,WAAA;QACA;QAEA,MAAAP,IAAA,cAAAgB,IAAA,CAAAS,cAAA,CAAAC,sBAAA,MAAAxB,WAAA,OAAAC,QAAA,EAAAoB,MAAA;QACA,KAAAtB,eAAA,IAAAD,IAAA,CAAA2B,IAAA,QAAAC,GAAA,CAAAC,GAAA;UACA,GAAAA,GAAA;UACAC,QAAA,EAAAD,GAAA,CAAAE,eAAA,GAAAF,GAAA,CAAAE,eAAA,CAAAC,KAAA;QACA;QACA,KAAA5B,KAAA,GAAAJ,IAAA,CAAAI,KAAA;MACA,SAAA6B,KAAA;QACA,KAAAd,QAAA,CAAAc,KAAA;MACA;QACA,KAAA5B,OAAA;MACA;IACA;IAEA6B,iBAAAC,IAAA;MACA,KAAAjC,WAAA,GAAAiC,IAAA;MACA,KAAAtB,gBAAA;IACA;IAEAuB,WAAAC,WAAA;MACA,KAAA5B,kBAAA,GAAA4B,WAAA;MACA,KAAA3B,YAAA,GAAA2B,WAAA,CAAA3B,YAAA;MACA,KAAAF,aAAA;IACA;IAEA,MAAA8B,kBAAAD,WAAA,EAAAE,MAAA;MACA;QACA,MAAAC,MAAA,GAAAD,MAAA;QACA,WAAAE,QAAA,OAAAD,MAAA;UAAAE,IAAA;QAAA;QAEA,WAAA1B,IAAA,CAAAS,cAAA,CAAAkB,iBAAA;UACAzB,EAAA,EAAAmB,WAAA,CAAAnB,EAAA;UACAX,WAAA,EAAAgC,MAAA;UACA7B,YAAA,EAAA6B,MAAA;QACA;QAEA,KAAApB,QAAA,CAAAyB,OAAA,IAAAJ,MAAA;QACA,WAAA3B,gBAAA;MACA,SAAAoB,KAAA;QACA,IAAAA,KAAA;UACA,KAAAd,QAAA,C