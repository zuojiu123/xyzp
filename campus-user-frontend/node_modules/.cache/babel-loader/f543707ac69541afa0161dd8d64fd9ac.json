n/**\n * 检查是否为企业用户\n */\nexport function isEnterpriseUser() {\n  return hasRole('Enterprise_User')\n}\n\n/**\n * 检查是否为普通用户\n */\nexport function isNormalUser() {\n  return hasRole('Normal_User')\n}\n\n/**\n * 检查是否为管理员\n */\nexport function isAdmin() {\n  return hasRole('Admin')\n}"],"mappings":"AAAA;;AAEA;AACA;AACA;AACA,OAAO,SAASA,QAAQA,CAAA,EAAG;EACzB,OAAOC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;AACtC;;AAEA;AACA;AACA;AACA,OAAO,SAASC,QAAQA,CAACC,KAAK,EAAE;EAC9BH,YAAY,CAACI,OAAO,CAAC,OAAO,EAAED,KAAK,CAAC;AACtC;;AAEA;AACA;AACA;AACA,OAAO,SAASE,WAAWA,CAAA,EAAG;EAC5BL,YAAY,CAACM,UAAU,CAAC,OAAO,CAAC;EAChCN,YAAY,CAACM,UAAU,CAAC,UAAU,CAAC;AACrC;;AAEA;AACA;AACA;AACA,OAAO,SAASC,WAAWA,CAAA,EAAG;EAC5B,IAAI;IACF,MAAMC,QAAQ,GAAGR,YAAY,CAACC,OAAO,CAAC,UAAU,CAAC;IACjD,OAAOO,QAAQ,GAAGC,IAAI,CAACC,KAAK,CAACF,QAAQ,CAAC,GAAG,IAAI;EAC/C,CAAC,CAAC,OAAOG,KAAK,EAAE;IACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK,CAAC;IACjC,OAAO,IAAI;EACb;AACF;;AAEA;AACA;AACA;AACA,OAAO,SAASE,WAAWA,CAACL,QAAQ,EAAE;EACpCR,YAAY,CAACI,OAAO,CAAC,UAAU,EAAEK,IAAI,CAACK,SAAS,CAACN,QAAQ,CAAC,CAAC;AAC5D;;AAEA;AACA;AACA;AACA,OAAO,SAASO,UAAUA,CAAA,EAAG;EAC3B,OAAO,CAAC,CAAChB,QAAQ,CAAC,CAAC;AACrB;;AAEA;AACA;AACA;AACA,OAAO,SAASiB,OAAOA,CAACC,IAAI,EAAE;EAC5B,MAAMT,QAAQ,GAAGD,WAAW,CAAC,CAAC;EAC9B,OAAOC,QAAQ,IAAIA,QAAQ,CAACS,IAAI,KAAKA,IAAI;AAC3C;;AAEA;AACA;AACA;AACA,OAAO,SAASC,gBAAgBA,CAAA,EAAG;EACjC,OAAOF,OAAO,CAAC,iBAAiB,CAAC;AACnC;;AAEA;AACA;AACA;AACA,OAAO,SAASG,YAAYA,CAAA,EAAG;EAC7B,OAAOH,OAAO,CAAC,aAAa,CAAC;AAC/B;;AAEA;AACA;AACA;AACA,OAAO,SAASI,OAAOA,CAAA,EAAG;EACxB,OAAOJ,OAAO,CAAC,OAAO,CAAC;AACzB","ignoreList":[]}]}