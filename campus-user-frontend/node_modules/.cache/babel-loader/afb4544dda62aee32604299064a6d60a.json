{"remainingRequest":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\babel-loader\\lib\\index.js!b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\src\\views\\company\\CompanyJobs.vue?vue&type=script&lang=js","dependencies":[{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\src\\views\\company\\CompanyJobs.vue","mtime":1760071435877},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1759980453610},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1759980457299},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1759980453610},{"path":"b:\\桌面文件\\campus-recruitment-system\\campus-user-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1759980458675}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["name","data","jobList","currentPage","pageSize","total","loading","dialogVisible","isEdit","submitting","jobForm","id","title","position","minSalary","maxSalary","description","treatment","jobRules","required","message","trigger","type","min","computed","dialogTitle","mounted","loadJobs","methods","$api","employment","getUserJobs","list","error","$message","handlePageChange","page","showCreateDialog","editJob","job","deleteJob","$confirm","success","submitJob","$refs","validate","valid","updateJob","createJob","resetForm","resetFields","getStatusType","status","types","getStatusText","texts","formatTime","timestamp","Date","toLocaleString"],"sources":["src/views/company/CompanyJobs.vue"],"sourcesContent":["<template>\n  <div class=\"company-jobs\">\n    <div class=\"container\">\n      <div class=\"header\">\n        <h2>职位管理</h2>\n        <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"showCreateDialog\">发布职位</el-button>\n      </div>\n\n      <el-card>\n        <el-table :data=\"jobList\" border v-loading=\"loading\">\n          <el-table-column prop=\"title\" label=\"职位名称\" width=\"200\"></el-table-column>\n          <el-table-column label=\"薪资范围\" width=\"150\">\n            <template slot-scope=\"scope\">\n              {{ scope.row.minSalary }}-{{ scope.row.maxSalary }}K\n            </template>\n          </el-table-column>\n          <el-table-column prop=\"position\" label=\"工作地点\" width=\"120\"></el-table-column>\n          <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n            <template slot-scope=\"scope\">\n              <el-tag :type=\"getStatusType(scope.row.status)\">\n                {{ getStatusText(scope.row.status) }}\n              </el-tag>\n            </template>\n          </el-table-column>\n          <el-table-column label=\"发布时间\" width=\"180\">\n            <template slot-scope=\"scope\">\n              {{ formatTime(scope.row.createTime) }}\n            </template>\n          </el-table-column>\n          <el-table-column label=\"操作\" width=\"200\">\n            <template slot-scope=\"scope\">\n              <el-button size=\"mini\" @click=\"editJob(scope.row)\">编辑</el-button>\n              <el-button size=\"mini\" type=\"danger\" @click=\"deleteJob(scope.row)\">删除</el-button>\n            </template>\n          </el-table-column>\n        </el-table>\n\n        <div class=\"pagination\">\n          <el-pagination\n            @current-change=\"handlePageChange\"\n            :current-page=\"currentPage\"\n            :page-size=\"pageSize\"\n            layout=\"total, prev, pager, next\"\n            :total=\"total\">\n          </el-pagination>\n        </div>\n      </el-card>\n\n      <!-- 创建/编辑职位对话框 -->\n      <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"600px\" @close=\"resetForm\">\n        <el-form :model=\"jobForm\" :rules=\"jobRules\" ref=\"jobForm\" label-width=\"100px\">\n          <el-form-item label=\"职位名称\" prop=\"title\">\n            <el-input v-model=\"jobForm.title\" placeholder=\"请输入职位名称\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"工作地点\" prop=\"position\">\n            <el-input v-model=\"jobForm.position\" placeholder=\"请输入工作地点\"></el-input>\n          </el-form-item>\n          <el-row :gutter=\"20\">\n            <el-col :span=\"12\">\n              <el-form-item label=\"最低薪资\" prop=\"minSalary\">\n                <el-input v-model.number=\"jobForm.minSalary\" placeholder=\"单位：K\">\n                  <template slot=\"append\">K</template>\n                </el-input>\n              </el-form-item>\n            </el-col>\n            <el-col :span=\"12\">\n              <el-form-item label=\"最高薪资\" prop=\"maxSalary\">\n                <el-input v-model.number=\"jobForm.maxSalary\" placeholder=\"单位：K\">\n                  <template slot=\"append\">K</template>\n                </el-input>\n              </el-form-item>\n            </el-col>\n          </el-row>\n          <el-form-item label=\"职位描述\" prop=\"description\">\n            <el-input type=\"textarea\" v-model=\"jobForm.description\" :rows=\"4\" placeholder=\"请详细描述职位要求和工作内容\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"福利待遇\" prop=\"treatment\">\n            <el-input type=\"textarea\" v-model=\"jobForm.treatment\" :rows=\"3\" placeholder=\"请描述福利待遇\"></el-input>\n          </el-form-item>\n        </el-form>\n        <div slot=\"footer\">\n          <el-button @click=\"dialogVisible = false\">取消</el-button>\n          <el-button type=\"primary\" @click=\"submitJob\" :loading=\"submitting\">\n            {{ isEdit ? '更新' : '发布' }}\n          </el-button>\n        </div>\n      </el-dialog>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CompanyJobs',\n  data() {\n    return {\n      jobList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      loading: false,\n      dialogVisible: false,\n      isEdit: false,\n      submitting: false,\n      jobForm: {\n        id: '',\n        title: '',\n        position: '',\n        minSalary: '',\n        maxSalary: '',\n        description: '',\n        treatment: ''\n      },\n      jobRules: {\n        title: [{ required: true, message: '请输入职位名称', trigger: 'blur' }],\n        position: [{ required: true, message: '请输入工作地点', trigger: 'blur' }],\n        minSalary: [\n          { required: true, message: '请输入最低薪资', trigger: 'blur' },\n          { type: 'number', message: '请输入数字', trigger: 'blur' }\n        ],\n        maxSalary: [\n          { required: true, message: '请输入最高薪资', trigger: 'blur' },\n          { type: 'number', message: '请输入数字', trigger: 'blur' }\n        ],\n        description: [\n          { required: true, message: '请输入职位描述', trigger: 'blur' },\n          { min: 20, message: '职位描述不能少于20个字符', trigger: 'blur' }\n        ]\n      }\n    }\n  },\n  computed: {\n    dialogTitle() {\n      return this.isEdit ? '编辑职位' : '发布职位'\n    }\n  },\n  async mounted() {\n    await this.loadJobs()\n  },\n  methods: {\n    async loadJobs() {\n      this.loading = true\n      try {\n        const data = await this.$api.employment.getUserJobs(this.currentPage, this.pageSize)\n        this.jobList = data.list || []\n        this.total = data.total || 0\n      } catch (error) {\n        this.$message.error('获取职位列表失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    \n    handlePageChange(page) {\n      this.currentPage = page\n      this.loadJobs()\n    },\n    \n    showCreateDialog() {\n      this.isEdit = false\n      this.dialogVisible = true\n    },\n    \n    editJob(job) {\n      this.isEdit = true\n      this.jobForm = { ...job }\n      this.dialogVisible = true\n    },\n    \n    async deleteJob(job) {\n      try {\n        await this.$confirm('确定要删除这个职位吗？', '提示', { type: 'warning' })\n        await this.$api.employment.deleteJob(job.id)\n        this.$message.success('删除成功')\n        await this.loadJobs()\n      } catch (error) {\n        if (error !== 'cancel') {\n          this.$message.error('删除失败')\n        }\n      }\n    },\n    \n    submitJob() {\n      this.$refs.jobForm.validate(async (valid) => {\n        if (!valid) return\n        \n        this.submitting = true\n        try {\n          if (this.isEdit) {\n            await this.$api.employment.updateJob(this.jobForm)\n            this.$message.success('更新成功')\n          } else {\n            await this.$api.employment.createJob(this.jobForm)\n            this.$message.success('发布成功，等待管理员审核')\n          }\n          this.dialogVisible = false\n          await this.loadJobs()\n        } catch (error) {\n          this.$message.error('操作失败：' + (error.message || '未知错误'))\n        } finally {\n          this.submitting = false\n        }\n      })\n    },\n    \n    resetForm() {\n      this.jobForm = {\n        id: '',\n        title: '',\n        position: '',\n        minSalary: '',\n        maxSalary: '',\n        description: '',\n        treatment: ''\n      }\n      if (this.$refs.jobForm) {\n        this.$refs.jobForm.resetFields()\n      }\n    },\n    \n    getStatusType(status) {\n      const types = { 0: 'info', 1: 'success', 2: 'danger' }\n      return types[status] || 'info'\n    },\n    \n    getStatusText(status) {\n      const texts = { 0: '待审核', 1: '已发布', 2: '已下线' }\n      return texts[status] || '未知'\n    },\n    \n    formatTime(timestamp) {\n      if (!timestamp) return ''\n      return new Date(timestamp).toLocaleString()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.company-jobs {\n  padding: 20px;\n  background: #f5f5f5;\n  min-height: calc(100vh - 120px);\n}\n\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\nh2 {\n  margin: 0;\n  color: #333;\n}\n\n.pagination {\n  text-align: center;\n  margin-top: 20px;\n}\n</style>\n"],"mappings":"AA4FA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;MACAC,OAAA;MACAC,aAAA;MACAC,MAAA;MACAC,UAAA;MACAC,OAAA;QACAC,EAAA;QACAC,KAAA;QACAC,QAAA;QACAC,SAAA;QACAC,SAAA;QACAC,WAAA;QACAC,SAAA;MACA;MACAC,QAAA;QACAN,KAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAR,QAAA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAP,SAAA,GACA;UAAAK,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,GACA;UAAAC,IAAA;UAAAF,OAAA;UAAAC,OAAA;QAAA,EACA;QACAN,SAAA,GACA;UAAAI,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,GACA;UAAAC,IAAA;UAAAF,OAAA;UAAAC,OAAA;QAAA,EACA;QACAL,WAAA,GACA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,GACA;UAAAE,GAAA;UAAAH,OAAA;UAAAC,OAAA;QAAA;MAEA;IACA;EACA;EACAG,QAAA;IACAC,YAAA;MACA,YAAAjB,MAAA;IACA;EACA;EACA,MAAAkB,QAAA;IACA,WAAAC,QAAA;EACA;EACAC,OAAA;IACA,MAAAD,SAAA;MACA,KAAArB,OAAA;MACA;QACA,MAAAL,IAAA,cAAA4B,IAAA,CAAAC,UAAA,CAAAC,WAAA,MAAA5B,WAAA,OAAAC,QAAA;QACA,KAAAF,OAAA,GAAAD,IAAA,CAAA+B,IAAA;QACA,KAAA3B,KAAA,GAAAJ,IAAA,CAAAI,KAAA;MACA,SAAA4B,KAAA;QACA,KAAAC,QAAA,CAAAD,KAAA;MACA;QACA,KAAA3B,OAAA;MACA;IACA;IAEA6B,iBAAAC,IAAA;MACA,KAAAjC,WAAA,GAAAiC,IAAA;MACA,KAAAT,QAAA;IACA;IAEAU,iBAAA;MACA,KAAA7B,MAAA;MACA,KAAAD,aAAA;IACA;IAEA+B,QAAAC,GAAA;MACA,KAAA/B,MAAA;MACA,KAAAE,OAAA;QAAA,GAAA6B;MAAA;MACA,KAAAhC,aAAA;IACA;IAEA,MAAAiC,UAAAD,GAAA;MACA;QACA,WAAAE,QAAA;UAAAnB,IAAA;QAAA;QACA,WAAAO,IAAA,CAAAC,UAAA,CAAAU,SAAA,CAAAD,GAAA,CAAA5B,EAAA;QACA,KAAAuB,QAAA,CAAAQ,OAAA;QACA,WAAAf,QAAA;MACA,SAAAM,KAAA;QACA,IAAAA,KAAA;UACA,KAAAC,QAAA,CAAAD,KAAA;QACA;MACA;IACA;IAEAU,UAAA;MACA,KAAAC,KAAA,CAAAlC,OAAA,CAAAmC,QAAA,OAAAC,KAAA;QACA,KAAAA,KAAA;QAEA,KAAArC,UAAA;QACA;UACA,SAAAD,MAAA;YACA,WAAAqB,IAAA,CAAAC,UAAA,CAAAiB,SAAA,MAAArC,OAAA;YACA,KAAAwB,QAAA,CAAAQ,OAAA;UACA;YACA,WAAAb,IAAA,CAAAC,UAAA,CAAAkB,SAAA,MAAAtC,OAAA;YACA,KAAAwB,QAAA,CAAAQ,OAAA;UACA;UACA,KAAAnC,aAAA;UACA,WAAAoB,QAAA;QACA,SAAAM,KAAA;UACA,KAAAC,QAAA